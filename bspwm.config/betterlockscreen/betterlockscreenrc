# ~/.config/betterlockscreen/betterlockscreenrc

# --- Colors ---
# (Using the same soft palette)
insidecolor="191724ff"
insidevercolor="26233aff"
insidewrongcolor="eb6f92ff"

ringcolor="908caaff"
ringvercolor="31748fff"
ringwrongcolor="eb6f92ff"

keyhlcolor="ebbcbaff"
bshlcolor="eb6f92ff"

separatorcolor="19172400" 

textcolor="e0def4ff"
verifcolor="c4a7e7ff"
wrongcolor="eb6f92ff"
timecolor="e0def4ff"
datecolor="908caaff"

# --- Typography & Text ---
font="sans-serif"
time_format="%H:%M"
date_format="%A, %d %B"

locktext="Type password..."
veriftext="Authenticating..."
wrongtext="Incorrect."

# --- Layout ---
locktext_size=18
veriftext_size=18
wrongtext_size=18

# Increased the time size to make the clock much bigger
time_size=84
date_size=20

# Added a semi-transparent dark box for the password area (Base color + CC for opacity)
loginbox="191724cc"
