[global]
    # Font and text settings
    font = Google Sans 11
    markup = full
    format = "<b>%s</b>\n%b"
    sort = yes
    indicate_hidden = yes
    alignment = left
    word_wrap = yes
    ignore_newline = no

    # Geometry (Bottom Right)
    # The format is "widthxheight+xoffset+yoffset"
    # width is 300, offset is 20px from right, 20px from bottom
    width = 300
    height = 300
    offset = 20x20

    # Aesthetics
    transparency = 0
    separator_height = 2
    padding = 15
    horizontal_padding = 15
    text_icon_padding = 15
    frame_width = 2
    corner_radius = 0

    # Icons
    icon_position = left
    max_icon_size = 64

    # Behavior
    idle_threshold = 120
    monitor = 0
    follow = mouse
    sticky_history = yes
    line_height = 0
    show_age_threshold = 60

    # Mouse actions (left click closes, middle click closes all, right click opens context)
    mouse_left_click = close_current
    mouse_middle_click = close_all
    mouse_right_click = context

[urgency_low]
    # Subtle gray/purple for background, muted text, no distracting borders
    background = "#232136"
    foreground = "#908caa"
    frame_color = "#393552"
    timeout = 5

[urgency_normal]
    # Surface color for background, bright text, primary purple border
    background = "#2a273f"
    foreground = "#e0def4"
    frame_color = "#c4a7e7"
    timeout = 10

[urgency_critical]
    # Base background, bright text, thick pink/red border for high alert
    background = "#232136"
    foreground = "#e0def4"
    frame_color = "#eb6f92"
    timeout = 0
